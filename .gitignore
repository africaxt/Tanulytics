# Trading-specific .gitignore

# Data & Backups
data/raw/
data/processed/
*.csv
*.parquet
*.xlsx
backups/

# Logs & Output
logs/
*.log
results/
reports/

# Credentials & Secrets
.env
.env.local
secrets/
keys/
config/api_keys.yaml
config/*.key

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Jupyter
.ipynb_checkpoints/
*.ipynb

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Trading specific
*.pkl
*.joblib
models/saved_models/
*.db
trading_sessions/
cache/

# Testing
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# OS
.DS_Store
Thumbs.db

# Large binaries & documents
*.pdf
*.jpg
*.jpeg
*.JPG
*.JPEG
*.png
*.PNG
*.eps
*.ai
*.numbers
*.xls
*.xls[xm]

# Google Drive native files
*.gdoc
*.gsheet
*.gform
*.gslides

# Branding assets
branding/

# Obsidian workspace state (personal, not shareable)
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# Obsidian journal & personal notes (private trading data)
journal/
inbox/
notes/

# Schwab token cache
config/.schwab_tokens.json

# Robinhood session cache
*.pickle
