# Tanulytics — Environment Variables Template
# Copy this file to .env and fill in your real values
# NEVER commit .env to git

# ── IBKR ──────────────────────────────────────────────────
IBKR_HOST=127.0.0.1
IBKR_TWS_PORT=7497
IBKR_GATEWAY_PORT=4001
IBKR_CLIENT_ID=99
IBKR_ACCOUNT_ID=your_account_id_here

# ── FXCM ──────────────────────────────────────────────────
# FXCM is now sourced via TradingView webhooks, not fxcmpy.
# tv_webhook_server.py receives Pine Script alert POSTs and appends them
# to data/raw/tv_fxcm_events.jsonl. fxcm_fetch.py reads that log and
# reconstructs current positions + realized P&L.
FXCM_WEBHOOK_SECRET=D-RM2crVX8MkyRASw5mrdr_cMl2DdqcGk2nboO9AYYE
FXCM_WEBHOOK_PORT=8787
FXCM_WEBHOOK_HOST=0.0.0.0
FXCM_LOOKBACK_DAYS=30
# To re-roll the secret:  python -c 'import secrets; print(secrets.token_urlsafe(32))'
# Expose locally with:    cloudflared tunnel --url http://localhost:8787
# Then paste this into TradingView alert webhook URL:
#   https://<your-cloudflared-host>.trycloudflare.com/fxcm-webhook/<FXCM_WEBHOOK_SECRET>
# Legacy fxcmpy-based config is no longer used; safe to remove.
# FXCM_ACCESS_TOKEN=...
# FXCM_SERVER=real

# ── Schwab ────────────────────────────────────────────────
SCHWAB_APP_KEY=your_schwab_app_key_here
SCHWAB_APP_SECRET=your_schwab_app_secret_here
SCHWAB_CALLBACK_URL=https://127.0.0.1
# Get from: developer.schwab.com → Individual Developer account
# schwabdev handles token refresh automatically
# Tokens are cached locally in config/.schwab_tokens.json — never commit it

# ── Robinhood ─────────────────────────────────────────────
ROBINHOOD_USERNAME=your_robinhood_email_here
ROBINHOOD_PASSWORD=your_robinhood_password_here
ROBINHOOD_TOTP_SECRET=your_totp_secret_here
# Recommended for automated daily runs:
#   Robinhood app → Settings → Security → 2FA → Authenticator app → "Other"
#   Robinhood will show an alphanumeric TOTP secret — paste it above.
#   Without this, robin_stocks will prompt stdin for SMS/email MFA codes
#   on every login, which blocks the automated pipeline.
# Note: robin_stocks is an unofficial wrapper — use with caution

# ── Airtable ──────────────────────────────────────────────
AIRTABLE_API_KEY=your_airtable_api_key_here
AIRTABLE_BASE_ID=your_base_id_here
# Get API key from: airtable.com/account → API section
# Base ID found in: airtable.com/api (select your base)

# ── Notion ────────────────────────────────────────────────
NOTION_API_KEY=your_notion_integration_token_here
# Get from: notion.so/my-integrations → Create new integration
# Share your Portfolio page with the integration after creating it

# ── General ───────────────────────────────────────────────
ENVIRONMENT=live          # live or paper
LOG_LEVEL=INFO            # DEBUG, INFO, WARNING, ERROR
